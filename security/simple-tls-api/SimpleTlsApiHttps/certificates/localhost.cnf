[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = distinguished_name
req_extensions = request_extensions

[distinguished_name]
C = IN
ST = Telangana
L = Hyderabad
O = Simple TLS API
OU = Development
CN = localhost

[request_extensions]
subjectAltName = @alternative_names

[alternative_names]
DNS.1 = localhost
DNS.2 = host.docker.internal
IP.1 = 127.0.0.1
IP.2 = ::1